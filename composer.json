{
    "name": "dgvirtual/codeigniter4-firebird",
    "description": "PDO-based Firebird/InterBase database driver for CodeIgniter 4",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Donatas Glodenis",
            "homepage": "https://github.com/dgvirtual"
        }
    ],
    "homepage": "https://github.com/dgvirtual/codeigniter4-firebird",
    "support": {
        "issues": "https://github.com/dgvirtual/codeigniter4-firebird/issues",
        "source": "https://github.com/dgvirtual/codeigniter4-firebird"
    },
    "keywords": ["codeigniter4", "firebird", "interbase", "database", "pdo"],
    "require": {
        "php": "^8.1",
        "ext-pdo": "*",
        "codeigniter4/framework": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Dgvirtual\\CI4Firebird\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dgvirtual\\CI4Firebird\\Tests\\Support\\": "tests/_support/"
        }
    }
}
